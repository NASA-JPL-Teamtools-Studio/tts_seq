        <xs:element maxOccurs="unbounded" ref="bitmask_mapping"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="bitmask_mapping">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="bitmask"/>
      </xs:sequence>
      <xs:attribute name="name" use="required" type="fsw-name-64-def"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="bitmask">
    <xs:complexType>
      <xs:attribute name="value" use="required" type="hex-only-int-32"/>
      <xs:attribute name="name" use="required" type="sys-name-64-def"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="module">
    <xs:complexType>
      <xs:sequence>
        <xs:element maxOccurs="unbounded" ref="group"/>
      </xs:sequence>
      <xs:attribute name="name" use="required" type="mission-module-def"/>
      <xs:attribute name="ops_category" use="required" type="mission-ops-category-def"/>
      <xs:attribute name="id" use="required" type="module-id-value"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="group">
    <xs:complexType>
      <xs:sequence>
        <xs:element maxOccurs="unbounded" ref="copy"/>
      </xs:sequence>
      <xs:attribute name="group_id" use="required" type="group-id-value"/>
      <xs:attribute name="group_name" use="required" type="sys-name-32-def"/>
      <xs:attribute name="is_atomic" use="required" type="xs:boolean"/>
      <xs:attribute name="group_description" use="required" type="xs:string"/>
      <xs:attribute name="version" use="required" type="group-version-value"/>
      <xs:attribute name="custom_validation_required" use="required">
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="Yes"/>
            <xs:enumeration value="No"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="custom_validation_description" type="xs:string"/>
      <xs:attribute name="set_action" use="required" type="xs:boolean"/>
