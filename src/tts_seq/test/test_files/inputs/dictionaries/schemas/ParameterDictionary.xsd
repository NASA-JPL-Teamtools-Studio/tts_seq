            </xs:extension>
          </xs:simpleContent>
        </xs:complexType>
      </xs:element>
    </xs:sequence>
  </xs:group>
  <xs:complexType name="categories-def">
    <xs:sequence>
      <xs:element ref="categories"/>
    </xs:sequence>
  </xs:complexType>
