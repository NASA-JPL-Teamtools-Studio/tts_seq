      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="point">
    <xs:complexType>
      <xs:attribute name="raw" use="required" type="xs:float"/>
      <xs:attribute name="eng" use="required" type="xs:float"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="polynomial_expansion">
    <xs:complexType>
      <xs:sequence>
        <xs:element maxOccurs="unbounded" ref="factor"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="factor">
    <xs:complexType>
      <xs:attribute name="index" use="required" type="poly-index-range-def"/>
      <xs:attribute name="coeff" use="required" type="xs:float"/>
    </xs:complexType>
  </xs:element>
  <xs:simpleType name="module-id-value">
    <xs:restriction base="xs:positiveInteger">
      <xs:maxInclusive value="32767"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="group-id-value">
    <xs:restriction base="unsigned-16-def"/>
  </xs:simpleType>
  <xs:simpleType name="copy-id-value">
    <xs:restriction base="unsigned-16-def"/>
  </xs:simpleType>
  <xs:simpleType name="param-id-value">
    <xs:restriction base="unsigned-16-def"/>
  </xs:simpleType>
  <xs:simpleType name="group-version-value">
    <xs:restriction base="unsigned-16-pos-def"/>
  </xs:simpleType>
  <xs:simpleType name="string-length-value">
    <xs:restriction base="xs:int">
      <xs:minInclusive value="1"/>
      <xs:maxInclusive value="128"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="param-range-value">
    <xs:restriction base="xs:token"/>
  </xs:simpleType>
  <xs:simpleType name="param-data-types">
    <xs:restriction base="xs:token">
      <xs:enumeration value="U8"/>
      <xs:enumeration value="U16"/>
      <xs:enumeration value="U32"/>
      <xs:enumeration value="I8"/>
      <xs:enumeration value="I16"/>
      <xs:enumeration value="I32"/>
      <xs:enumeration value="F32"/>
      <xs:enumeration value="F64"/>
      <xs:enumeration value="ENUM"/>
      <xs:enumeration value="STRING"/>
      <xs:enumeration value="BOOL"/>
      <xs:enumeration value="BITMASK"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:element name="ParameterDictionary">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="header"/>
        <xs:element minOccurs="0" ref="enum_definitions"/>
        <xs:element minOccurs="0" ref="bitmask_mappings"/>
        <xs:element maxOccurs="unbounded" ref="module"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="enum_definitions">
