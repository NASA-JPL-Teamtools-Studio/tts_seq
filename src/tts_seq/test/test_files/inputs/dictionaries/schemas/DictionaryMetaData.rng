      <value>reu_mgr</value>
      <value>rm_ctl</value>
      <value>rt_drv</value>
      <value>rt_mgr</value>
      <value>rt_svc</value>
      <value>rts_svc</value>
      <value>sarb_svc</value>
      <value>sbs_svc</value>
      <value>sfp_exe</value>
      <value>sc_app</value>
      <value>scfg_svc</value>
      <value>scu_ctl</value>
      <value>scu_mgr</value>
      <value>seq_svc</value>
      <value>sfp_exe</value>
      <value>shell_app</value>
      <value>shell_ctl</value>
