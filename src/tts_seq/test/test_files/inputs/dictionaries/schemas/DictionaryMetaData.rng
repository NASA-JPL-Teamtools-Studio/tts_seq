<?xml version="1.0" encoding="UTF-8"?>
<grammar xmlns="http://relaxng.org/ns/structure/1.0"
         xmlns:rng="http://relaxng.org/ns/structure/1.0"
         datatypeLibrary="http://www.w3.org/2001/XMLSchema-datatypes">
  <define name="name-def">
    <data type="token">
      <param name="pattern">[A-Za-z0-9_\-]{1,64}</param>
    </data>
  </define>
  <define name="fsw-name-def">
    <data type="token">
      <param name="pattern">[a-z0-9_]{1,32}</param>
    </data>
  </define>
  <define name="fsw-name-64-def">
    <data type="token">
      <param name="pattern">[a-z0-9_]{1,64}</param>
    </data>
  </define>
  <define name="sys-name-32-def">
    <data type="token">
      <param name="pattern">[A-Z0-9_]{1,32}</param>
    </data>
  </define>
  <define name="sys-name-64-def">
    <data type="token">
      <param name="pattern">[A-Z0-9_]{1,64}</param>
    </data>
  </define>
  <define name="sys-name-128-def">
    <data type="token">
      <param name="pattern">[A-Z0-9_]{1,128}</param>
    </data>
  </define>
  <define name="name-128-def">
    <data type="token">
      <param name="pattern">[A-Za-z0-9_\-]{1,128}</param>
    </data>
  </define>
  <define name="name-16-def">
    <data type="token">
      <param name="pattern">[A-Za-z0-9_\-]{1,16}</param>
    </data>
  </define>
  <define name="symbol-def">
    <data type="token">
      <param name="maxLength">64</param>
    </data>
  </define>
  <define name="symbol-def-32">
    <data type="token">
      <param name="maxLength">32</param>
    </data>
  </define>
  <define name="signed-64-pos-def">
    <data type="nonNegativeInteger"/>
  </define>
  <define name="unsigned-32-def">
    <data type="nonNegativeInteger">
      <param name="maxInclusive">4294967295</param>
    </data>
  </define>
  <define name="unsigned-16-def">
    <data type="nonNegativeInteger">
      <param name="maxInclusive">65535</param>
    </data>
  </define>
  <define name="unsigned-16-pos-def">
    <data type="positiveInteger">
      <param name="maxInclusive">65535</param>
    </data>
  </define>
  <define name="unsigned-8-def">
    <data type="nonNegativeInteger">
      <param name="maxInclusive">255</param>
    </data>
  </define>
  <define name="unsigned-8-pos-def">
    <data type="positiveInteger">
      <param name="maxInclusive">255</param>
    </data>
  </define>
  <define name="offset-64-def">
    <data type="nonNegativeInteger">
      <param name="maxInclusive">63</param>
    </data>
  </define>
  <define name="string-400-def">
    <data type="normalizedString">
      <param name="maxLength">400</param>
    </data>
  </define>
  <define name="string-512-def">
    <data type="normalizedString">
      <param name="maxLength">512</param>
    </data>
  </define>
  <define name="non-empty-token-def">
    <data type="token">
      <param name="minLength">1</param>
    </data>
  </define>
  <define name="token-64-def">
    <data type="token">
      <param name="maxLength">64</param>
    </data>
  </define>
  <define name="c-format-string-def">
    <data type="token">
      <param name="pattern">[^%]*%{0,1}[^%]+</param>
    </data>
  </define>
  <define name="string-type-def">
    <attribute>
      <name ns="">type</name>
      <choice>
        <value>fixed_length</value>
        <value>length_prefixed</value>
      </choice>
    </attribute>
  </define>
  <define name="header-def">
    <element>
      <name ns="">header</name>
      <attribute>
        <name ns="">mission_name</name>
        <value>ProjectXYZ</value>
      </attribute>
      <optional>
        <element>
          <name ns="">spacecraft_ids</name>
          <oneOrMore>
            <element>
              <name ns="">spacecraft_id</name>
              <attribute>
                <name ns="">value</name>
                <data type="nonNegativeInteger"/>
              </attribute>
            </element>
          </oneOrMore>
        </element>
      </optional>
      <attribute>
        <name ns="">version</name>
        <data type="token"/>
      </attribute>
      <attribute>
        <name ns="">schema_version</name>
        <data type="token"/>
      </attribute>
    </element>
  </define>
  <define name="enum-def">
    <element>
      <name ns="">enum</name>
      <attribute>
        <name ns="">symbol</name>
        <ref name="sys-name-64-def"/>
      </attribute>
      <attribute>
        <name ns="">numeric</name>
        <data type="int"/>
      </attribute>
    </element>
  </define>
  <define name="enum-table-def">
    <element>
      <name ns="">enum_table</name>
      <attribute>
        <name ns="">name</name>
        <ref name="name-def"/>
      </attribute>
      <optional>
        <attribute>
          <name ns="">export</name>
          <value>yes</value>
        </attribute>
      </optional>
      <element>
        <name ns="">values</name>
        <oneOrMore>
          <ref name="enum-def"/>
        </oneOrMore>
      </element>
    </element>
  </define>
  <define name="parameterized-algorithm-def">
    <element>
      <name ns="">parameterized_algorithm</name>
      <attribute>
        <name ns="">name</name>
        <data type="token"/>
      </attribute>
      <zeroOrMore>
        <ref name="algorithm-parameter-def"/>
      </zeroOrMore>
    </element>
  </define>
  <define name="algorithm-parameter-def">
    <element>
      <name ns="">parameter</name>
      <attribute>
        <name ns="">name</name>
        <ref name="name-def"/>
      </attribute>
      <data type="string"/>
    </element>
  </define>
  <define name="categories-def">
    <element>
      <name ns="">categories</name>
      <group>
        <optional>
          <element>
            <name ns="">module</name>
            <ref name="mission-module-def"/>
          </element>
        </optional>
        <element>
          <name ns="">ops_category</name>
          <ref name="mission-ops-category-def"/>
        </element>
      </group>
    </element>
  </define>
  <define name="system-mode-def">
    <choice>
      <value>TEST</value>
      <value>PRE-LAUNCH</value>
      <value>LAUNCH</value>
      <value>CRUISE</value>
      <value>EDL APPROACH</value>
      <value>EDL MAIN</value>
      <value>SURFACE NOMINAL</value>
      <value>SURFACE STANDBY</value>
    </choice>
  </define>
