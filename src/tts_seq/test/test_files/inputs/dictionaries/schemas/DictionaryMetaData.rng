    <choice>
      <value>aclk_mgr</value>
      <value>acm_svc</value>
      <value>acs_ctl</value>
      <value>adc_svc</value>
      <value>adl_svc</value>
      <value>aman_ctl</value>
      <value>ant_mgr</value>
      <value>app_exe</value>
      <value>app_svc</value>
      <value>arm_ctl</value>
      <value>asia_drv</value>
      <value>asiadis_drv</value>
      <value>asiadis_mgr</value>
      <value>atif_drv</value>
      <value>atifdis_drv</value>
      <value>atifdis_mgr</value>
      <value>bc_drv</value>
      <value>bc_mgr</value>
      <value>cbm_ctl</value>
      <value>cfdp_svc</value>
      <value>cic_drv</value>
      <value>cmd_svc</value>
      <value>cmod_svc</value>
      <value>coll_svc</value>
      <value>comm_mgr</value>
      <value>comp_svc</value>
      <value>cpu_drv</value>
      <value>crc_drv</value>
      <value>crc_mgr</value>
      <value>cstr_mgr</value>
      <value>data_app</value>
      <value>dimu_drv</value>
      <value>dimu_mgr</value>
      <value>dm_mgr</value>
      <value>dma_drv</value>
      <value>dpc_svc</value>
      <value>dpm_svc</value>
      <value>dpt_svc</value>
      <value>dsa_mgr</value>
      <value>dwn_app</value>
      <value>dwn_drv</value>
      <value>dwn_mgr</value>
      <value>ecam_mgr</value>
      <value>edl_ctl</value>
      <value>edlbg_svc</value>
      <value>edlcam_mgr</value>
      <value>edlcomm_svc</value>
      <value>edlgnc</value>
      <value>eha_svc</value>
      <value>enet_drv</value>
      <value>evr_svc</value>
      <value>file_svc</value>
      <value>fpm_svc</value>
      <value>frame_mgr</value>
      <value>fv_svc</value>
      <value>gate_svc</value>
      <value>gid_mgr</value>
      <value>grip_ctl</value>
      <value>health_svc</value>
      <value>helo_mgr</value>
      <value>hsm_svc</value>
      <value>hst_svc</value>
      <value>hsuart_drv</value>
      <value>iccitc_drv</value>
      <value>imf_svc</value>
      <value>iml_svc</value>
      <value>ivp_svc</value>
      <value>kd_svc</value>
