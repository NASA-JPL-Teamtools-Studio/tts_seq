      <value>upl_app</value>
      <value>upl_drv</value>
      <value>upl_mgr</value>
      <value>ust_mgr</value>
      <value>utils_svc</value>
      <value>vce_mgr</value>
      <value>vis_ctl</value>
      <value>vislib_svc</value>
      <value>zfit_app</value>
      <value>zfit_uth</value>
      <value>zfit_worker</value>
    </choice>
  </define>
  <define name="mission-ops-category-def">
    <choice>
      <value>ACM</value>
      <value>ACS</value>
      <value>AVS</value>
      <value>BCTL</value>
      <value>CBM</value>
      <value>CMD</value>
      <value>CTB</value>
      <value>DDM</value>
      <value>DMX</value>
      <value>DWN</value>
      <value>EDL</value>
      <value>FSW</value>
      <value>HDW</value>
      <value>IMG</value>
      <value>LMC</value>
      <value>LPCE</value>
      <value>MDLI</value>
      <value>MLS</value>
      <value>PRM</value>
      <value>PWR</value>
      <value>PYRO</value>
      <value>REU</value>
      <value>RSB</value>
      <value>SAM</value>
      <value>SAPP</value>
      <value>SDEP</value>
      <value>SEQ</value>
      <value>SFP</value>
      <value>SMC</value>
      <value>SPW</value>
      <value>SRH</value>
      <value>STS</value>
      <value>TEL</value>
      <value>THRM</value>
      <value>TIME</value>
      <value>UPL</value>
      <value>VCE</value>
      <value>WAKE</value>
    </choice>
  </define>
  <define name="mission_phase">
    <value>LAUNCH</value>
  </define>
  <define name="channel-id-def">
    <data type="token">
      <param name="pattern">[A-Z]{1}[A-Z0-9]{0,3}-[0-9]{4}</param>
    </data>
  </define>
  <define name="hex-only-int">
    <data type="token">
      <param name="pattern">[0-9A-F]+</param>
    </data>
  </define>
  <define name="hex-only-int-16">
    <data type="token">
      <param name="pattern">0[x][0-9A-F]+</param>
      <param name="length">6</param>
    </data>
  </define>
  <define name="hex-only-int-32">
    <data type="token">
      <param name="pattern">0[x][0-9A-F]+</param>
      <param name="length">10</param>
    </data>
  </define>
  <define name="hex-int">
    <data type="token">
      <param name="pattern">[0-9]+|0x[0-9A-F]+</param>
    </data>
  </define>
  <define name="apid-range-def">
    <data type="nonNegativeInteger">
      <param name="maxExclusive">2047</param>
    </data>
  </define>
  <define name="stem-def">
    <data type="token">
      <param name="pattern">[A-Z][A-Z0-9_]{1,32}</param>
    </data>
  </define>
  <define name="icmd-stem-def">
    <data type="token">
      <param name="pattern">[A-Z][A-Z0-9_]{1,64}</param>
    </data>
  </define>
  <define name="poly-index-range-def">
    <data type="nonNegativeInteger">
      <param name="maxInclusive">7</param>
    </data>
  </define>
  <define name="product-viewer-def">
    <element>
      <name ns="">viewer</name>
      <attribute>
        <name ns="">name</name>
        <text/>
      </attribute>
      <choice>
        <empty/>
        <text/>
      </choice>
    </element>
  </define>
  <define name="table-lookup-def">
    <element>
      <name ns="">table_lookup</name>
      <zeroOrMore>
        <element>
          <name ns="">point</name>
          <attribute>
            <name ns="">raw</name>
            <data type="float"/>
          </attribute>
          <attribute>
            <name ns="">eng</name>
            <data type="float"/>
          </attribute>
        </element>
      </zeroOrMore>
    </element>
  </define>
  <define name="poly-def">
    <element>
      <name ns="">polynomial_expansion</name>
      <oneOrMore>
        <element>
          <name ns="">factor</name>
          <attribute>
            <name ns="">index</name>
            <ref name="poly-index-range-def"/>
          </attribute>
          <attribute>
            <name ns="">coeff</name>
            <data type="float"/>
          </attribute>
        </element>
      </oneOrMore>
    </element>
  </define>
  <start>
    <ref name="dictionary-meta-data-def"/>
  </start>
  <define name="dictionary-meta-data-def">
    <element>
      <name ns="">dictionary_meta_data</name>
      <ref name="meta-data-header-def"/>
      <zeroOrMore>
        <ref name="dictionary-meta-def"/>
      </zeroOrMore>
      <zeroOrMore>
        <ref name="vi-tracking-def"/>
      </zeroOrMore>
    </element>
  </define>
  <define name="meta-data-header-def">
    <element>
      <name ns="">meta_data_header</name>
      <attribute>
        <name ns="">mission_name</name>
        <value>ProjectXYZ</value>
      </attribute>
    </element>
  </define>
  <define name="dictionary-meta-def">
    <element>
      <name ns="">dictionary_meta</name>
      <attribute>
        <name ns="">element_type</name>
        <ref name="dictionary-elements-def"/>
      </attribute>
      <attribute>
        <name ns="">element_id</name>
        <text/>
      </attribute>
      <attribute>
        <name ns="">element_name</name>
        <text/>
      </attribute>
      <attribute>
        <name ns="">flight_ground</name>
        <choice>
          <value>Flight</value>
          <value>Ground</value>
        </choice>
      </attribute>
      <attribute>
        <name ns="">flight_system_poc</name>
        <text/>
      </attribute>
      <optional>
        <attribute>
          <name ns="">fsw_developer</name>
          <text/>
        </attribute>
      </optional>
      <optional>
        <element>
          <name ns="">vnv_planning</name>
          <attribute>
            <name ns="">vnv_planned</name>
            <choice>
              <value>true_explicit</value>
              <value>true_data_review</value>
              <value>discovery</value>
              <value>unplanned</value>
            </choice>
          </attribute>
          <optional>
            <attribute>
              <name ns="">system_vac</name>
              <data type="token"/>
            </attribute>
          </optional>
          <optional>
            <attribute>
              <name ns="">system_va</name>
              <data type="token"/>
            </attribute>
          </optional>
          <optional>
            <attribute>
              <name ns="">system_va_id</name>
              <data type="token"/>
            </attribute>
          </optional>
          <optional>
            <attribute>
              <name ns="">test_case</name>
              <data type="token"/>
            </attribute>
          </optional>
          <optional>
            <attribute>
              <name ns="">planning_notes</name>
              <data type="token"/>
            </attribute>
          </optional>
          <optional>
            <attribute>
              <name ns="">l3_l4_vnv_owner</name>
              <text/>
            </attribute>
          </optional>
          <optional>
            <attribute>
              <name ns="">l5_vnv_owner</name>
              <text/>
            </attribute>
          </optional>
          <optional>
            <attribute>
              <name ns="">sys_test_release</name>
              <text/>
            </attribute>
          </optional>
          <optional>
            <attribute>
              <name ns="">fit_test_release</name>
              <text/>
            </attribute>
          </optional>
          <optional>
            <attribute>
              <name ns="">atlo_safety</name>
              <choice>
                <value>Yes</value>
                <value>No</value>
              </choice>
            </attribute>
          </optional>
        </element>
      </optional>
      <optional>
        <element>
          <name ns="">dictionary_information</name>
          <optional>
            <attribute>
              <name ns="">ops_category</name>
              <data type="token"/>
            </attribute>
          </optional>
          <optional>
            <attribute>
              <name ns="">module</name>
              <data type="token"/>
            </attribute>
          </optional>
          <optional>
            <attribute>
              <name ns="">system_description</name>
              <data type="string"/>
            </attribute>
          </optional>
        </element>
      </optional>
    </element>
  </define>
  <define name="vi-tracking-def">
    <element>
      <name ns="">vi_tracking</name>
      <element>
        <name ns="">dictionary_item_summary</name>
        <attribute>
          <name ns="">element_type</name>
          <ref name="dictionary-elements-def"/>
        </attribute>
        <attribute>
          <name ns="">element_id</name>
          <text/>
        </attribute>
        <attribute>
          <name ns="">element_name</name>
          <text/>
        </attribute>
      </element>
      <element>
        <name ns="">release</name>
        <attribute>
          <name ns="">level</name>
          <choice>
            <value>FSW I&amp;T</value>
            <value>Avionics System I&amp;T</value>
            <value>System I&amp;T</value>
          </choice>
        </attribute>
        <attribute>
          <name ns="">fsw_version</name>
          <text/>
        </attribute>
        <attribute>
          <name ns="">dictionary_version</name>
          <text/>
        </attribute>
        <optional>
          <attribute>
            <name ns="">sse_version</name>
            <text/>
          </attribute>
        </optional>
        <optional>
          <attribute>
            <name ns="">gds_version</name>
            <text/>
          </attribute>
        </optional>
      </element>
      <element>
        <name ns="">results</name>
        <attribute>
          <name ns="">test_date</name>
          <data type="date"/>
        </attribute>
        <oneOrMore>
          <choice>
            <ref name="test-method-def"/>
            <ref name="analysis-inspect-method-def"/>
          </choice>
        </oneOrMore>
        <attribute>
          <name ns="">status</name>
          <choice>
            <value>PASS</value>
            <value>FAIL</value>
            <value>PARTIAL</value>
            <value>PARTIAL_DEFAULT</value>
          </choice>
        </attribute>
        <zeroOrMore>
          <choice>
            <ref name="dpfr-pfr-def"/>
            <ref name="other-def"/>
            <ref name="jira-def"/>
          </choice>
        </zeroOrMore>
        <optional>
          <attribute>
            <name ns="">run_for_record</name>
            <choice>
              <value>Yes</value>
              <value>No</value>
            </choice>
          </attribute>
        </optional>
        <optional>
          <attribute>
            <name ns="">notes</name>
            <text/>
          </attribute>
        </optional>
      </element>
      <optional>
        <element>
          <name ns="">atlo_ready</name>
          <attribute>
            <name ns="">atlo_approval</name>
            <choice>
              <value>APPROVED</value>
              <value>NOT_APPROVED</value>
              <value>LIMITED_USE</value>
            </choice>
          </attribute>
          <optional>
            <attribute>
              <name ns="">limited_use</name>
              <text/>
            </attribute>
          </optional>
        </element>
      </optional>
      <zeroOrMore>
        <element>
          <name ns="">review</name>
          <attribute>
            <name ns="">vnv_reviewer</name>
            <text/>
          </attribute>
          <optional>
            <attribute>
              <name ns="">vnv_review_notes</name>
              <text/>
            </attribute>
          </optional>
        </element>
      </zeroOrMore>
    </element>
  </define>
  <define name="dictionary-elements-def">
    <choice>
      <value>APID</value>
      <value>CHANNEL</value>
      <value>COMMAND</value>
      <value>DATA PRODUCT</value>
      <value>EVR</value>
    </choice>
  </define>
  <define name="test-method-def">
    <element>
      <name ns="">test_method</name>
      <attribute>
        <name ns="">activity_report</name>
        <text/>
      </attribute>
      <attribute>
        <name ns="">machine</name>
        <text/>
      </attribute>
      <attribute>
        <name ns="">session_id</name>
        <text/>
      </attribute>
      <optional>
        <attribute>
          <name ns="">test_conductor</name>
          <text/>
        </attribute>
      </optional>
      <optional>
        <attribute>
          <name ns="">data_review</name>
          <text/>
        </attribute>
      </optional>
      <attribute>
        <name ns="">test_procedure</name>
        <text/>
      </attribute>
      <optional>
        <attribute>
          <name ns="">fp_injection</name>
          <text/>
        </attribute>
      </optional>
    </element>
  </define>
  <define name="analysis-inspect-method-def">
    <element>
      <name ns="">analysis_inspect_method</name>
      <oneOrMore>
        <choice>
          <ref name="ext-docs-def"/>
          <ref name="short-report-def"/>
        </choice>
      </oneOrMore>
    </element>
  </define>
  <define name="ext-docs-def">
    <element>
      <name ns="">ext_docs</name>
      <attribute>
        <name ns="">description</name>
        <text/>
      </attribute>
      <attribute>
        <name ns="">http_link</name>
        <text/>
      </attribute>
    </element>
  </define>
  <define name="short-report-def">
    <element>
      <name ns="">short_report</name>
      <attribute>
        <name ns="">report</name>
        <text/>
      </attribute>
    </element>
  </define>
  <define name="dpfr-pfr-def">
    <element>
      <name ns="">dpfr_pfr</name>
      <attribute>
        <name ns="">prs_id</name>
        <data type="token">
          <param name="pattern">[0-9]+</param>
        </data>
      </attribute>
      <attribute>
        <name ns="">prs_link</name>
        <data type="token"/>
      </attribute>
      <attribute>
        <name ns="">description</name>
        <text/>
      </attribute>
    </element>
  </define>
  <define name="other-def">
    <element>
      <name ns="">other_anom</name>
      <attribute>
        <name ns="">description</name>
        <text/>
      </attribute>
    </element>
  </define>
  <define name="jira-def">
    <element>
      <name ns="">jira</name>
      <attribute>
        <name ns="">jira_issue</name>
        <text/>
      </attribute>
      <attribute>
        <name ns="">jira_link</name>
        <text/>
      </attribute>
      <attribute>
        <name ns="">description</name>
        <text/>
      </attribute>
    </element>
  </define>
</grammar>
