<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" elementFormDefault="qualified">
  <!--
    General definition of data type used for names. Since names may be stored in 
    databases or searchable as text, the allowed character set is limited to 
    letters, numbers, underscores, and dashes, and length is restricted to 64.
  -->
  <xs:simpleType name="name-def">
    <xs:restriction base="xs:token">
      <xs:pattern value="[A-Za-z0-9_\-]{1,64}"/>
    </xs:restriction>
  </xs:simpleType>
  <!--
    Helix Implementation: FSW Name must not be any one of the 32 reserved words in C
    auto       double   int          struct
    break     else        long       switch
    case       enum     register typedef
    char       extern   return    union
    const     float      short      unsigned
    continue              for          signed   void
    default  goto      sizeof    volatile
    do          if             static     while
  -->
  <xs:simpleType name="fsw-name-def">
    <xs:restriction base="xs:token">
      <xs:pattern value="[a-z0-9_]{1,32}"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="fsw-name-64-def">
    <xs:restriction base="xs:token">
      <xs:pattern value="[a-z0-9_]{1,64}"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="sys-name-32-def">
    <xs:restriction base="xs:token">
      <xs:pattern value="[A-Z0-9_]{1,32}"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="sys-name-64-def">
    <xs:restriction base="xs:token">
      <xs:pattern value="[A-Z0-9_]{1,64}"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="sys-name-128-def">
    <xs:restriction base="xs:token">
      <xs:pattern value="[A-Z0-9_]{1,128}"/>
    </xs:restriction>
  </xs:simpleType>
  <!--
    General definition of data type used for long names. Since names may be 
    stored in databases or searchable as text, the allowed character set is limited 
    to letters, numbers, underscores, and dashes, and length is restricted to 128.
  -->
  <xs:simpleType name="name-128-def">
    <xs:restriction base="xs:token">
      <xs:pattern value="[A-Za-z0-9_\-]{1,128}"/>
    </xs:restriction>
  </xs:simpleType>
  <!--
    General definition of data type used for short names. Since names may be 
    stored in databases or searchable as text, the allowed character set is limited 
    to letters, numbers, underscores, and dashes, and length is restricted to 16.
  -->
  <xs:simpleType name="name-16-def">
    <xs:restriction base="xs:token">
      <xs:pattern value="[A-Za-z0-9_\-]{1,16}"/>
    </xs:restriction>
  </xs:simpleType>
  <!--
    General definition of an enumeration symbol or short name. Limited
    to 64 characters in length.
  -->
  <xs:simpleType name="symbol-def">
    <xs:restriction base="xs:token">
      <xs:maxLength value="64"/>
    </xs:restriction>
  </xs:simpleType>
  <!--
    General definition of an enumeration symbol or short name. Limited
    to 32 characters in length.
  -->
  <xs:simpleType name="symbol-def-32">
    <xs:restriction base="xs:token">
      <xs:maxLength value="32"/>
    </xs:restriction>
  </xs:simpleType>
  <!-- signed-64-pos-def -->
  <xs:simpleType name="signed-64-pos-def">
    <xs:restriction base="xs:nonNegativeInteger"/>
  </xs:simpleType>
  <!-- General definition for 32 bit unsigned values. Range is limited to 4294967295. -->
  <xs:simpleType name="unsigned-32-def">
    <xs:restriction base="xs:nonNegativeInteger">
      <xs:maxInclusive value="4294967295"/>
    </xs:restriction>
  </xs:simpleType>
  <!-- General definition for 16 bit unsigned values. Range is limited to 65535. -->
  <xs:simpleType name="unsigned-16-def">
    <xs:restriction base="xs:nonNegativeInteger">
      <xs:maxInclusive value="65535"/>
    </xs:restriction>
  </xs:simpleType>
  <!-- General definition for 16 bit unsigned positive values. Range is limited to 65535. -->
  <xs:simpleType name="unsigned-16-pos-def">
    <xs:restriction base="xs:positiveInteger">
      <xs:maxInclusive value="65535"/>
    </xs:restriction>
  </xs:simpleType>
  <!-- General definition for 8 bit unsigned values. Range is limited to 255. -->
  <xs:simpleType name="unsigned-8-def">
    <xs:restriction base="xs:nonNegativeInteger">
      <xs:maxInclusive value="255"/>
    </xs:restriction>
  </xs:simpleType>
  <!-- General definition for 8 bit unsigned positive values. Range is limited to 255. -->
  <xs:simpleType name="unsigned-8-pos-def">
    <xs:restriction base="xs:positiveInteger">
      <xs:maxInclusive value="255"/>
    </xs:restriction>
  </xs:simpleType>
  <!-- General definition for 0-63 bit offset values. -->
  <xs:simpleType name="offset-64-def">
    <xs:restriction base="xs:nonNegativeInteger">
      <xs:maxInclusive value="63"/>
    </xs:restriction>
  </xs:simpleType>
  <!-- General definition for a 400 character-length string. -->
  <xs:simpleType name="string-400-def">
    <xs:restriction base="xs:normalizedString">
      <xs:maxLength value="400"/>
    </xs:restriction>
  </xs:simpleType>
  <!-- General definition for a 512 character-length string. -->
  <xs:simpleType name="string-512-def">
    <xs:restriction base="xs:normalizedString">
      <xs:maxLength value="512"/>
    </xs:restriction>
  </xs:simpleType>
  <!-- General definition for a non-empty token field -->
  <xs:simpleType name="non-empty-token-def">
    <xs:restriction base="xs:token">
      <xs:minLength value="1"/>
    </xs:restriction>
  </xs:simpleType>
  <!-- General definition for a 64-character token field -->
  <xs:simpleType name="token-64-def">
    <xs:restriction base="xs:token">
      <xs:maxLength value="64"/>
    </xs:restriction>
  </xs:simpleType>
  <!-- A standard C format string to represent the output of this field -->
  <xs:simpleType name="c-format-string-def">
    <xs:restriction base="xs:token">
      <xs:pattern value="[^%]*%{0,1}[^%]+"/>
    </xs:restriction>
  </xs:simpleType>
  <!--
    Type of string value. fixed_length implies the string argument occupies 
    the entire data length in the received packet. length_prefixed implies 
    that an actual data length field precedes the actual variable 
    length string data. This length must be an unsigned value
    in the data.
    
  -->
  <xs:attributeGroup name="string-type-def">
    <xs:attribute name="type" use="required">
      <xs:simpleType>
        <xs:restriction base="xs:token">
          <xs:enumeration value="fixed_length"/>
          <xs:enumeration value="length_prefixed"/>
        </xs:restriction>
      </xs:simpleType>
    </xs:attribute>
  </xs:attributeGroup>
  <!-- Common dictionary header, to be included in all dictionaries. -->
  <xs:element name="header">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" ref="spacecraft_ids"/>
      </xs:sequence>
      <xs:attribute name="mission_name" use="required">
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="ProjectXYZ"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="version" use="required" type="xs:token"/>
      <xs:attribute name="schema_version" use="required" type="xs:token"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="spacecraft_ids">
    <xs:complexType>
      <xs:sequence>
        <xs:element maxOccurs="unbounded" ref="spacecraft_id"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="spacecraft_id">
    <xs:complexType>
      <xs:attribute name="value" use="required" type="xs:nonNegativeInteger"/>
    </xs:complexType>
  </xs:element>
  <!--
    General enumeration value element. Used to map a string symbol to numeric value 
    or vice-versa. In most cases, the numeric value is used and transmitted by the 
    flight software. The symbolic value is mapped to numeric value on the ground.
  -->
  <xs:element name="enum">
    <xs:complexType>
      <xs:attribute name="symbol" use="required" type="sys-name-64-def"/>
      <xs:attribute name="numeric" use="required" type="xs:int"/>
    </xs:complexType>
  </xs:element>
  <!--
    General enumeration table, which provides a named list of 0 or more 
    enumeration value elements
  -->
  <xs:element name="enum_table">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="values"/>
      </xs:sequence>
      <xs:attribute name="name" use="required" type="name-def"/>
      <xs:attribute name="export">
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="yes"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="values">
    <xs:complexType>
      <xs:sequence>
        <xs:element maxOccurs="unbounded" ref="enum"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <!--
    General algorithm definition for algorithms that may take parameters and 
    specify a return type. Such algorithms are used to compute custom telemetry 
    or product values on the ground.  
  -->
  <xs:element name="parameterized_algorithm">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="parameter"/>
      </xs:sequence>
      <xs:attribute name="name" use="required" type="xs:token"/>
    </xs:complexType>
  </xs:element>
  <!--
    Defines a parameter to an algorithm. Note that all parameters are strings, 
    so the algorithm developer must know the data types expected.
  -->
  <xs:element name="parameter">
    <xs:complexType>
      <xs:simpleContent>
        <xs:extension base="xs:string">
          <xs:attribute name="name" use="required" type="name-def"/>
        </xs:extension>
      </xs:simpleContent>
    </xs:complexType>
  </xs:element>
  <!--
    This is used to categorize items into groups. Possible category names 
    are "module", "ops category", "subsystem", ...
    It is possible that there are multiple ways of organizing groups of 
    elements, so that there may be more than one category entry for a given 
    item.
  -->
  <xs:element name="categories">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" ref="module"/>
        <xs:element ref="ops_category"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
