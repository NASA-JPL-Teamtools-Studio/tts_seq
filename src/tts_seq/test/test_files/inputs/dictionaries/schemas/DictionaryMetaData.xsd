  <xs:simpleType name="mission_phase">
    <xs:restriction base="xs:token">
      <xs:enumeration value="LAUNCH"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="channel-id-def">
    <xs:restriction base="xs:token">
      <xs:pattern value="[A-Z]{1}[A-Z0-9]{0,3}-[0-9]{4}"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="hex-only-int">
    <xs:restriction base="xs:token">
      <xs:pattern value="[0-9A-F]+"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="hex-only-int-16">
    <xs:restriction base="xs:token">
      <xs:pattern value="0[x][0-9A-F]+"/>
      <xs:length value="6"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="hex-only-int-32">
    <xs:restriction base="xs:token">
      <xs:pattern value="0[x][0-9A-F]+"/>
      <xs:length value="10"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="hex-int">
    <xs:restriction base="xs:token">
      <xs:pattern value="[0-9]+|0x[0-9A-F]+"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="apid-range-def">
    <xs:restriction base="xs:nonNegativeInteger">
      <xs:maxExclusive value="2047"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="stem-def">
    <xs:restriction base="xs:token">
      <xs:pattern value="[A-Z][A-Z0-9_]{1,32}"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="icmd-stem-def">
    <xs:restriction base="xs:token">
      <xs:pattern value="[A-Z][A-Z0-9_]{1,64}"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="poly-index-range-def">
    <xs:restriction base="xs:nonNegativeInteger">
      <xs:maxInclusive value="7"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:element name="viewer">
    <xs:complexType mixed="true">
      <xs:attribute name="name" use="required"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="table_lookup">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="point"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="point">
    <xs:complexType>
      <xs:attribute name="raw" use="required" type="xs:float"/>
      <xs:attribute name="eng" use="required" type="xs:float"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="polynomial_expansion">
    <xs:complexType>
      <xs:sequence>
        <xs:element maxOccurs="unbounded" ref="factor"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="factor">
    <xs:complexType>
      <xs:attribute name="index" use="required" type="poly-index-range-def"/>
      <xs:attribute name="coeff" use="required" type="xs:float"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="dictionary_meta_data">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="meta_data_header"/>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="dictionary_meta"/>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="vi_tracking"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="meta_data_header">
    <xs:complexType>
      <xs:attribute name="mission_name" use="required">
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="ProjectXYZ"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="dictionary_meta">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" ref="vnv_planning"/>
        <xs:element minOccurs="0" ref="dictionary_information"/>
      </xs:sequence>
      <xs:attribute name="element_type" use="required" type="dictionary-elements-def"/>
      <xs:attribute name="element_id" use="required"/>
      <xs:attribute name="element_name" use="required"/>
      <xs:attribute name="flight_ground" use="required">
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="Flight"/>
            <xs:enumeration value="Ground"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="flight_system_poc" use="required"/>
      <xs:attribute name="fsw_developer"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="vnv_planning">
    <xs:complexType>
      <xs:attribute name="vnv_planned" use="required">
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="true_explicit"/>
            <xs:enumeration value="true_data_review"/>
            <xs:enumeration value="discovery"/>
            <xs:enumeration value="unplanned"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="system_vac" type="xs:token"/>
      <xs:attribute name="system_va" type="xs:token"/>
      <xs:attribute name="system_va_id" type="xs:token"/>
      <xs:attribute name="test_case" type="xs:token"/>
      <xs:attribute name="planning_notes" type="xs:token"/>
      <xs:attribute name="l3_l4_vnv_owner"/>
      <xs:attribute name="l5_vnv_owner"/>
      <xs:attribute name="sys_test_release"/>
      <xs:attribute name="fit_test_release"/>
      <xs:attribute name="atlo_safety">
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="Yes"/>
            <xs:enumeration value="No"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
    </xs:complexType>
  </xs:element>
  <xs:element name="dictionary_information">
    <xs:complexType>
      <xs:attribute name="ops_category" type="xs:token"/>
      <xs:attribute name="module" type="xs:token"/>
      <xs:attribute name="system_description" type="xs:string"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="vi_tracking">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="dictionary_item_summary"/>
        <xs:element ref="release"/>
        <xs:element ref="results"/>
        <xs:element minOccurs="0" ref="atlo_ready"/>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="review"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="dictionary_item_summary">
    <xs:complexType>
      <xs:attribute name="element_type" use="required" type="dictionary-elements-def"/>
      <xs:attribute name="element_id" use="required"/>
      <xs:attribute name="element_name" use="required"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="release">
    <xs:complexType>
      <xs:attribute name="level" use="required">
        <xs:simpleType>
          <xs:restriction base="xs:token">
            <xs:enumeration value="FSW I&amp;T"/>
            <xs:enumeration value="Avionics System I&amp;T"/>
            <xs:enumeration value="System I&amp;T"/>
          </xs:restriction>
        </xs:simpleType>
      </xs:attribute>
      <xs:attribute name="fsw_version" use="required"/>
      <xs:attribute name="dictionary_version" use="required"/>
      <xs:attribute name="sse_version"/>
      <xs:attribute name="gds_version"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="results">
    <xs:complexType>
      <xs:sequence>
        <xs:choice maxOccurs="unbounded">
          <xs:element ref="test_method"/>
          <xs:element ref="analysis_inspect_method"/>
        </xs:choice>
