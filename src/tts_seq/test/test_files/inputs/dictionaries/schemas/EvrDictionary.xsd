  <xs:simpleType name="mission_phase">
    <xs:restriction base="xs:token">
      <xs:enumeration value="LAUNCH"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="channel-id-def">
    <xs:restriction base="xs:token">
      <xs:pattern value="[A-Z]{1}[A-Z0-9]{0,3}-[0-9]{4}"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="hex-only-int">
    <xs:restriction base="xs:token">
      <xs:pattern value="[0-9A-F]+"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="hex-only-int-16">
    <xs:restriction base="xs:token">
      <xs:pattern value="0[x][0-9A-F]+"/>
      <xs:length value="6"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="hex-only-int-32">
    <xs:restriction base="xs:token">
      <xs:pattern value="0[x][0-9A-F]+"/>
      <xs:length value="10"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="hex-int">
    <xs:restriction base="xs:token">
      <xs:pattern value="[0-9]+|0x[0-9A-F]+"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="apid-range-def">
    <xs:restriction base="xs:nonNegativeInteger">
      <xs:maxExclusive value="2047"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="stem-def">
    <xs:restriction base="xs:token">
      <xs:pattern value="[A-Z][A-Z0-9_]{1,32}"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="icmd-stem-def">
    <xs:restriction base="xs:token">
      <xs:pattern value="[A-Z][A-Z0-9_]{1,64}"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="poly-index-range-def">
    <xs:restriction base="xs:nonNegativeInteger">
      <xs:maxInclusive value="7"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:element name="viewer">
    <xs:complexType mixed="true">
      <xs:attribute name="name" use="required"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="table_lookup">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="point"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="point">
    <xs:complexType>
      <xs:attribute name="raw" use="required" type="xs:float"/>
      <xs:attribute name="eng" use="required" type="xs:float"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="polynomial_expansion">
    <xs:complexType>
      <xs:sequence>
        <xs:element maxOccurs="unbounded" ref="factor"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="factor">
    <xs:complexType>
      <xs:attribute name="index" use="required" type="poly-index-range-def"/>
      <xs:attribute name="coeff" use="required" type="xs:float"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="evr_dictionary">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="header"/>
        <xs:element minOccurs="0" ref="enum_definitions"/>
        <xs:element ref="evrs"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="enum_definitions">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="enum_table"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="evrs">
    <xs:complexType>
      <xs:sequence>
        <xs:element minOccurs="0" maxOccurs="unbounded" ref="evr"/>
      </xs:sequence>
    </xs:complexType>
  </xs:element>
  <xs:element name="evr">
    <xs:complexType>
      <xs:sequence>
        <xs:element ref="categories"/>
        <xs:element minOccurs="0" ref="description"/>
        <xs:element ref="format_message"/>
        <xs:element ref="number_of_arguments"/>
        <xs:element minOccurs="0" ref="args"/>
      </xs:sequence>
      <xs:attribute name="id" use="required" type="hex-only-int-32"/>
      <xs:attribute name="name" use="required" type="name-128-def"/>
      <xs:attribute name="level" use="required" type="evr-level"/>
      <xs:attribute name="source" use="required" type="evr-source-def"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="description" type="xs:string"/>
  <xs:element name="format_message" type="string-400-def"/>
  <xs:element name="number_of_arguments">
    <xs:simpleType>
      <xs:restriction base="xs:nonNegativeInteger">
        <xs:minInclusive value="0"/>
        <xs:maxInclusive value="11"/>
      </xs:restriction>
    </xs:simpleType>
  </xs:element>
  <xs:element name="args">
    <xs:complexType>
      <xs:choice maxOccurs="unbounded">
        <xs:element ref="string_arg"/>
        <xs:element ref="enum_arg"/>
        <xs:element ref="opcode_arg"/>
        <xs:element ref="seqid_arg"/>
        <xs:element ref="integer_arg"/>
        <xs:element ref="unsigned_arg"/>
        <xs:element ref="float_arg"/>
      </xs:choice>
    </xs:complexType>
  </xs:element>
  <xs:element name="string_arg">
    <xs:complexType>
      <xs:attribute name="name" use="required" type="name-def"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="enum_arg">
    <xs:complexType>
      <xs:attribute name="name" use="required" type="name-def"/>
      <xs:attribute name="byte_length" use="required" type="enum-argument-length-def"/>
      <xs:attribute name="enum_name" use="required" type="name-def"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="integer_arg">
    <xs:complexType>
      <xs:attribute name="name" use="required" type="name-def"/>
      <xs:attribute name="byte_length" use="required" type="integer-argument-length-def"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="unsigned_arg">
    <xs:complexType>
      <xs:attribute name="name" use="required" type="name-def"/>
      <xs:attribute name="byte_length" use="required" type="integer-argument-length-def"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="float_arg">
    <xs:complexType>
      <xs:attribute name="name" use="required" type="name-def"/>
      <xs:attribute name="byte_length" use="required" type="float-argument-length-def"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="opcode_arg">
    <xs:complexType>
      <xs:attribute name="name" use="required" type="name-def"/>
      <xs:attribute name="byte_length" use="required" type="opcode-argument-length-def"/>
    </xs:complexType>
  </xs:element>
  <xs:element name="seqid_arg">
    <xs:complexType>
      <xs:attribute name="name" use="required" type="name-def"/>
      <xs:attribute name="byte_length" use="required" type="seqid-argument-length-def"/>
    </xs:complexType>
  </xs:element>
  <xs:simpleType name="integer-argument-length-def">
    <xs:restriction base="xs:token">
      <xs:enumeration value="1"/>
      <xs:enumeration value="2"/>
      <xs:enumeration value="4"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="float-argument-length-def">
    <xs:restriction base="xs:token">
      <xs:enumeration value="8"/>
    </xs:restriction>
  </xs:simpleType>
  <xs:simpleType name="opcode-argument-length-def">
    <xs:restriction base="xs:token">
      <xs:enumeration value="2"/>
